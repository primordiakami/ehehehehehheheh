<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step Type"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_step_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_console_input"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Coordinates -->
        <LinearLayout
            android:id="@+id/layout_coordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="X"
                android:inputType="number"
                android:text="0"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Y"
                android:inputType="number"
                android:text="0"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp" />
        </LinearLayout>

        <!-- End Coordinates (for swipe) -->
        <LinearLayout
            android:id="@+id/layout_end_coordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/et_end_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="End X"
                android:inputType="number"
                android:text="0"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_end_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="End Y"
                android:inputType="number"
                android:text="0"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Duration and Delay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_duration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Duration (ms)"
                android:inputType="number"
                android:text="100"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_delay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Delay (ms)"
                android:inputType="number"
                android:text="0"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Text Input -->
        <LinearLayout
            android:id="@+id/layout_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter text"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Python Code -->
        <LinearLayout
            android:id="@+id/layout_python"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Python Code"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_python_code"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Enter Python code"
                android:textColor="@color/console_text"
                android:textColorHint="@color/on_surface_disabled"
                android:background="@drawable/bg_console_input"
                android:padding="12dp"
                android:gravity="top"
                android:fontFamily="monospace"
                android:inputType="textMultiLine|textNoSuggestions" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
